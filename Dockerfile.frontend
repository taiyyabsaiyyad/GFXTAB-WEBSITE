# Multi-stage Dockerfile for MockupAI Studio Frontend
# GFXTAB Productions · Taiyyab Saiyyad

FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm install --legacy-peer-deps
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
# Reconfigure default Nginx config to listen on port 5173 as mapped in docker-compose
RUN sed -i 's/listen\( \)*80;/listen 5173;/g' /etc/nginx/conf.d/default.conf
EXPOSE 5173
CMD ["nginx", "-g", "daemon off;"]
