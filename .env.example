# GFXTAB AI Studio — Environment Variables Configuration

# Frontend
VITE_API_URL=http://localhost:4000
VITE_AI_SERVICE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-key-here
VITE_PAYMENT_VPA=your-upi-vpa-here


# Backend
PORT=4000
JWT_SECRET=change-this-to-a-very-long-random-256bit-secret-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
AI_SERVICE_URL=http://localhost:8000

# Supabase Admin (Backend only)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Cloudflare R2 / Supabase Storage
STORAGE_BUCKET=gfxtab-assets
STORAGE_PUBLIC_URL=https://assets.gfxtab.studio

# Redis (Cache)
REDIS_URL=redis://default:password@your-redis-instance:6379

# AI Service Configs
HUGGINGFACE_TOKEN=hf_your_token_here
MODEL_CACHE_DIR=/tmp/models
MAX_IMAGE_SIZE_MB=25
